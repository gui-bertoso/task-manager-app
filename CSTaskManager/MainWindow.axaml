<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="CSTaskManager.MainWindow"
        Title="CSTaskManager">
    <StackPanel Margin="20">
        <TextBox x:Name="TaskNameInput" Width="300" Watermark="Write a task name"/>
        <TextBox x:Name="TaskDescriptionInput" Width="300" Watermark="Write a task description"/>
        <Button Content="Add Task" Click="AddTask_Click" Margin="0, 5, 0, 10"/>
        <ListBox x:Name="TasksListBox" Width="300" Height="400">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Name}">
                        <ToolTip.Tip>
                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" MaxWidth="300" />
                        </ToolTip.Tip>
                    </TextBlock>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </StackPanel>
</Window>
